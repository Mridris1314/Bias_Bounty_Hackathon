# -------- App --------
APP_ENV=dev
CORS_ORIGINS=["http://localhost:3000"]

# -------- LLM (crew brain) --------
# RECOMMENDED: Gemini free tier (gemini-2.5-flash or gemini-2.0-flash).
# Reliable tool-calling and generous per-minute throughput for this
# pipeline's 2 real LLM calls per run (battery/probe/metrics are
# deterministic tool calls, not LLM calls — see crew/orchestrator.py).
# Get a free key at https://aistudio.google.com.
CREW_LLM_MODEL=gemini/gemini-2.5-flash
OLLAMA_BASE_URL=http://localhost:11434

# Only the key matching the active CREW_LLM_MODEL prefix needs to be set.
# Supported prefixes: ollama/..., gemini/..., groq/..., openai/..., anthropic/...
# Note: Groq's free tier has proven quite rate-limit-prone for this
# pipeline in testing (low tokens-per-minute caps); Ollama works but is
# slow and less reliable at structured tool-calling with small local models.
GROQ_API_KEY=
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Retry behavior for transient/rate-limit errors from the crew LLM. A retry
# restarts the crew from its first LLM task, so keep this reasonably high
# for free-tier providers with tight per-minute limits.
ENABLE_RETRY=true
MAX_RETRIES=5
# Pause between the crew's sequential LLM calls so token/request usage
# spreads across the provider's rolling per-minute window. Not needed for
# ollama (no rate limit), applied automatically for everything else.
INTER_AGENT_PACING_S=15

# -------- Vector DB --------
# Option A: Qdrant Cloud (free tier)
#   Sign up at https://cloud.qdrant.io, create a cluster, paste URL + key below.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=regulations

# Option B (fallback if QDRANT_URL is empty): local Chroma
CHROMA_PERSIST_DIR=./data/chroma

# -------- Embeddings --------
# Called remotely via the Gemini embeddings API (uses GEMINI_API_KEY
# above) rather than a local model — much lighter on memory, matters on
# constrained deploys like Render's free tier (512MB runtime cap).
EMBEDDING_MODEL=gemini-embedding-001

# -------- Storage --------
SQLITE_URL=sqlite:///./data/biasbounty.db

# -------- Audit runtime --------
MAX_PROMPTS_PER_DIMENSION=4
REQUEST_TIMEOUT_S=30
MAX_CONCURRENT_PROBES=3
